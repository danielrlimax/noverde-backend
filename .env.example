# =====================================================
# SOLVERDE BACKEND - VARIÁVEIS DE AMBIENTE
# =====================================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env!
# =====================================================

# =====================================================
# AMBIENTE
# =====================================================
NODE_ENV=development
PORT=3001

# =====================================================
# SUPABASE (Obrigatório)
# =====================================================
# Encontre em: Dashboard > Settings > API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua-service-role-key

# =====================================================
# JWT & SEGURANÇA (Obrigatório)
# =====================================================
# IMPORTANTE: Gere chaves únicas e fortes!
# Comando: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=GERE_UMA_CHAVE_SEGURA_DE_64_BYTES_AQUI
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=GERE_OUTRA_CHAVE_SEGURA_DE_64_BYTES_AQUI
JWT_REFRESH_EXPIRES_IN=7d

# Chave de criptografia (exatamente 32 caracteres)
# Comando: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=GERE_CHAVE_DE_32_CARACTERES_AQUI

# =====================================================
# CORS - URLs Permitidas
# =====================================================
# Separe múltiplas URLs por vírgula
# IMPORTANTE: Atualize com suas URLs reais!

# Desenvolvimento
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Produção (exemplo - atualize com seus domínios)
# CORS_ALLOWED_ORIGINS=https://solverde.vercel.app,https://www.solverde.com.br,https://solverde.com.br

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_AUTH_REQUESTS=5

# =====================================================
# E-MAIL (Opcional - desconsiderar por enquanto)
# =====================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# EMAIL_FROM=SolVerde <noreply@solverde.com.br>
# EMAIL_ADMIN=admin@solverde.com.br

# =====================================================
# LOGS
# =====================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# =====================================================
# ADMIN INICIAL
# =====================================================
# Usuário admin criado automaticamente no primeiro deploy
# MUDE A SENHA IMEDIATAMENTE APÓS O PRIMEIRO LOGIN!
ADMIN_EMAIL=admin@solverde.com.br
ADMIN_PASSWORD=SolVerde@2024!

# =====================================================
# RENDER.COM ESPECÍFICO
# =====================================================
# O Render configura automaticamente:
# - PORT (não precisa definir)
# - NODE_ENV=production (em produção)
#
# Configure as outras variáveis no painel do Render:
# Dashboard > Your Service > Environment
# =====================================================
